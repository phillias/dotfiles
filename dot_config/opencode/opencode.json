{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "google/gemini-2.0-flash",
  "provider": {
    "opencode-go": {
      "models": {}
    },
    "groq": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Groq",
      "options": {
        "baseURL": "https://api.groq.com/openai/v1",
        "apiKey": "{env:GROQ_API_KEY}"
      },
      "models": {}
    },
    "openrouter": {
      "models": {}
    },
    "cerebras": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cerebras",
      "options": {
        "baseURL": "https://api.cerebras.ai/v1",
        "apiKey": "{env:CEREBRAS_API_KEY}"
      },
      "models": {}
    },
    "fireworks-ai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Fireworks",
      "options": {
        "baseURL": "https://api.fireworks.ai/inference/v1",
        "apiKey": "{env:FIREWORKS_API_KEY}"
      },
      "models": {}
    },
    "mistral": {
      "npm": "@ai-sdk/mistral",
      "name": "Mistral",
      "options": {
        "apiKey": "{env:MISTRAL_API_KEY}"
      },
      "models": {}
    },
    "sambanova": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "SambaNova",
      "options": {
        "baseURL": "https://api.sambanova.ai/v1",
        "apiKey": "{env:SAMBANOVA_API_KEY}"
      },
      "models": {}
    },
    "google": {
      "npm": "@ai-sdk/google",
      "name": "Google",
      "options": {
        "apiKey": "{env:GOOGLE_API_KEY}"
      },
      "models": {}
    },
    "together": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Together",
      "options": {
        "baseURL": "https://api.together.xyz/v1",
        "apiKey": "{env:TOGETHER_API_KEY}"
      },
      "models": {}
    },
    "kilocode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kilo Gateway",
      "options": {
        "baseURL": "https://api.kilo.ai/api/gateway"
      },
      "models": {}
    },
    "huggingface": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "HuggingFace",
      "options": {
        "baseURL": "https://router.huggingface.co/v1"
      },
      "models": {}
    },
    "opencode-zen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Zen",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1",
        "apiKey": "{env:OPENCODE_ZEN_API_KEY}"
      },
      "models": {}
    },
    "cloudflare": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cloudflare Workers AI",
      "options": {
        "baseURL": "https://api.cloudflare.com/client/v4/accounts/a7fa198dd5b359a187c671064fe6b36e/ai/v1",
        "apiKey": "{file:~/.config/opencode/.cloudflare-key}"
      },
      "models": {
        "cloudflare/llama-3.3-70b": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
        "cloudflare/llama-4-scout": "@cf/meta/llama-4-scout-17b-16e-instruct",
        "cloudflare/llama-3.2-3b": "@cf/meta/llama-3.2-3b-instruct",
        "cloudflare/llama-3.1-8b": "@cf/meta/llama-3.1-8b-instruct-fp8",
        "cloudflare/deepseek-r1-32b": "@cf/deepseek-ai/deepseek-r1-distill-qwen-32b",
        "cloudflare/qwen-coder-32b": "@cf/qwen/qwen2.5-coder-32b-instruct",
        "cloudflare/qwen3-30b": "@cf/qwen/qwen3-30b-a3b-fp8",
        "cloudflare/gpt-oss-120b": "@cf/openai/gpt-oss-120b",
        "cloudflare/gpt-oss-20b": "@cf/openai/gpt-oss-20b",
        "cloudflare/kimi-k2.6": "@cf/moonshotai/kimi-k2.6",
        "cloudflare/kimi-k2.7-code": "@cf/moonshotai/kimi-k2.7-code",
        "cloudflare/glm-4.7-flash": "@cf/zai-org/glm-4.7-flash",
        "cloudflare/glm-5.2": "@cf/zai-org/glm-5.2",
        "cloudflare/mistral-small-24b": "@cf/mistralai/mistral-small-3.1-24b-instruct",
        "cloudflare/qwq-32b": "@cf/qwen/qwq-32b"
      }
    }
  },
  "compaction": {
    "auto": false,
    "prune": true,
    "reserved": 50000,
    "tail_turns": 40
  },
  "mcp": {
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "oauth": false,
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}"
      }
    },
    "codemem": {
      "type": "local",
      "command": ["codemem", "mcp"],
      "enabled": true
    }
  },
  "lsp": true,
  "formatter": {
    "prettier-json": {
      "command": ["npx", "prettier", "--write", "--parser", "json"],
      "extensions": [".json", ".jsonc"]
    },
    "prettier-yaml": {
      "command": ["npx", "prettier", "--write", "--parser", "yaml"],
      "extensions": [".yaml", ".yml"]
    }
  }
}
