{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "google/gemini-2.0-flash",
  "provider": {
    "opencode-go": {
      "models": {}
    },
    "groq": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Groq",
      "options": {
        "baseURL": "https://api.groq.com/openai/v1",
        "apiKey": "{env:GROQ_API_KEY}"
      },
      "models": {}
    },
    "openrouter": {
      "models": {}
    },
    "cerebras": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cerebras",
      "options": {
        "baseURL": "https://api.cerebras.ai/v1",
        "apiKey": "{env:CEREBRAS_API_KEY}"
      },
      "models": {}
    },
    "fireworks-ai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Fireworks",
      "options": {
        "baseURL": "https://api.fireworks.ai/inference/v1",
        "apiKey": "{env:FIREWORKS_API_KEY}"
      },
      "models": {}
    },
    "mistral": {
      "npm": "@ai-sdk/mistral",
      "name": "Mistral",
      "options": {
        "apiKey": "{env:MISTRAL_API_KEY}"
      },
      "models": {}
    },
    "sambanova": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "SambaNova",
      "options": {
        "baseURL": "https://api.sambanova.ai/v1",
        "apiKey": "{env:SAMBANOVA_API_KEY}"
      },
      "models": {}
    },
    "google": {
      "npm": "@ai-sdk/google",
      "name": "Google",
      "options": {
        "apiKey": "{env:GOOGLE_API_KEY}"
      },
      "models": {}
    },
    "together": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Together",
      "options": {
        "baseURL": "https://api.together.xyz/v1",
        "apiKey": "{env:TOGETHER_API_KEY}"
      },
      "models": {}
    },
    "kilocode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kilo Gateway",
      "options": {
        "baseURL": "https://api.kilo.ai/api/gateway"
      },
      "models": {}
    },
    "huggingface": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "HuggingFace",
      "options": {
        "baseURL": "https://router.huggingface.co/v1"
      },
      "models": {}
    },
    "opencode-zen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Zen",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1",
        "apiKey": "{env:OPENCODE_ZEN_API_KEY}"
      },
      "models": {}
    }
  },
  "compaction": {
    "auto": false,
    "prune": true,
    "reserved": 50000,
    "tail_turns": 40
  },
  "mcp": {
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "oauth": false,
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}"
      }
    },
    "codemem": {
      "type": "local",
      "command": ["codemem", "mcp"],
      "enabled": true
    }
  },
  "lsp": true,
  "formatter": {
    "prettier-json": {
      "command": ["npx", "prettier", "--write", "--parser", "json"],
      "extensions": [".json", ".jsonc"]
    },
    "prettier-yaml": {
      "command": ["npx", "prettier", "--write", "--parser", "yaml"],
      "extensions": [".yaml", ".yml"]
    }
  }
}
