{
  "$schema": "https://opencode.ai/theme.json",
  "description": "Solarized palette with Tokyonight emphasis — readable muted text, vivid accents, blue-gray body",
  "defs": {
    "bg":       "#002b36",
    "bgAlt":    "#073642",
    "bgPanel":  "#00212b",
    "muted":    "#787c99",
    "subtle":   "#586e75",
    "body":     "#93a1a1",
    "text":     "#b8c2c2",
    "bright":   "#c8d2d2",
    "yellow":   "#b58900",
    "orange":   "#cb4b16",
    "red":      "#dc322f",
    "magenta":  "#d33682",
    "violet":   "#6c71c4",
    "blue":     "#268bd2",
    "cyan":     "#2aa198",
    "green":    "#859900"
  },
  "theme": {
    "primary":   { "dark": "blue",     "light": "violet" },
    "secondary": { "dark": "cyan",     "light": "blue" },
    "accent":    { "dark": "violet",   "light": "magenta" },
    "error":     { "dark": "red",      "light": "red" },
    "warning":   { "dark": "orange",   "light": "orange" },
    "success":   { "dark": "green",    "light": "green" },
    "info":      { "dark": "cyan",     "light": "blue" },
    "text":            { "dark": "body",   "light": "bgAlt" },
    "textMuted":       { "dark": "muted",  "light": "muted" },
    "background":      { "dark": "bg",     "light": "#fdf6e3" },
    "backgroundPanel": { "dark": "bgAlt",  "light": "#eee8d5" },
    "backgroundElement": { "dark": "bgAlt", "light": "#eee8d5" },
    "border":          { "dark": "subtle", "light": "subtle" },
    "borderActive":    { "dark": "muted",  "light": "muted" },
    "borderSubtle":    { "dark": "bgAlt",  "light": "#eee8d5" },
    "diffAdded":         { "dark": "green",  "light": "green" },
    "diffRemoved":       { "dark": "red",    "light": "red" },
    "diffContext":       { "dark": "muted",  "light": "muted" },
    "diffHunkHeader":    { "dark": "muted",  "light": "muted" },
    "diffHighlightAdded":  { "dark": "green", "light": "green" },
    "diffHighlightRemoved":{ "dark": "red",   "light": "red" },
    "diffAddedBg":    { "dark": "bgAlt", "light": "#eee8d5" },
    "diffRemovedBg":  { "dark": "bgAlt", "light": "#eee8d5" },
    "diffContextBg":  { "dark": "bgAlt", "light": "#eee8d5" },
    "diffLineNumber": { "dark": "subtle", "light": "subtle" },
    "diffAddedLineNumberBg":   { "dark": "bgAlt", "light": "#eee8d5" },
    "diffRemovedLineNumberBg": { "dark": "bgAlt", "light": "#eee8d5" },
    "markdownText":          { "dark": "body",   "light": "bgAlt" },
    "markdownHeading":       { "dark": "cyan",   "light": "blue" },
    "markdownLink":          { "dark": "blue",   "light": "blue" },
    "markdownLinkText":      { "dark": "violet", "light": "violet" },
    "markdownCode":          { "dark": "green",  "light": "green" },
    "markdownBlockQuote":    { "dark": "muted",  "light": "muted" },
    "markdownEmph":          { "dark": "orange", "light": "orange" },
    "markdownStrong":        { "dark": "text",   "light": "bg" },
    "markdownHorizontalRule":{ "dark": "muted",  "light": "muted" },
    "markdownListItem":      { "dark": "cyan",   "light": "blue" },
    "markdownListEnumeration": { "dark": "violet", "light": "violet" },
    "markdownImage":         { "dark": "blue",   "light": "blue" },
    "markdownImageText":     { "dark": "violet", "light": "violet" },
    "markdownCodeBlock":     { "dark": "body",   "light": "bgAlt" },
    "syntaxComment":    { "dark": "subtle", "light": "subtle" },
    "syntaxKeyword":    { "dark": "violet", "light": "violet" },
    "syntaxFunction":   { "dark": "blue",   "light": "blue" },
    "syntaxVariable":   { "dark": "orange", "light": "orange" },
    "syntaxString":     { "dark": "green",  "light": "green" },
    "syntaxNumber":     { "dark": "magenta","light": "magenta" },
    "syntaxType":       { "dark": "yellow", "light": "yellow" },
    "syntaxOperator":   { "dark": "cyan",   "light": "blue" },
    "syntaxPunctuation":{ "dark": "body",   "light": "bgAlt" }
  }
}
