{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-openagent.schema.json",

  "disabled_hooks": ["no-hephaestus-non-gpt"],

  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 401, 402, 403, 429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 1,
    "cooldown_seconds": 30,
    "timeout_seconds": 60,
    "notify_on_fallback": true
  },

  // ── Team Mode ──────────────────────────────────────────────
  // Parallel multi-agent coordination via 12 team_* tools.
  // Lead agent (sisyphus) delegates to up to 4 parallel members.
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "tmux_visualization": true,
    "max_messages_per_run": 10000,
    "max_wall_clock_minutes": 120,
    "max_member_turns": 500,
    "message_payload_max_bytes": 32768,
    "recipient_unread_max_bytes": 262144,
    "mailbox_poll_interval_ms": 3000
  },

  // ── Tmux Integration ───────────────────────────────────────
  // Spawns background subagents in dedicated tmux panes.
  // Use .tmux-OmOTeam.conf for custom team-mode tmux styling.
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },

  "background_task": {
    "defaultConcurrency": 8,
    "providerConcurrency": {
      "opencode": 15,
      "opencode-zen": 15,
      "opencode-go": 8,
      "openrouter": 6,
      "cloudflare": 10
    },
    "modelConcurrency": {
      "opencode-zen/big-pickle": 2,
      "opencode-go/kimi-k2.6": 3,
      "opencode-go/deepseek-v4-pro": 2,
      "opencode-go/gpt-5.5": 2,
      "opencode-go/gpt-5.4": 2,
      "opencode-go/gpt-5.3-codex": 2,
      "opencode-go/glm-5.1": 2,
      "opencode-go/deepseek-v4-flash": 15,
      "opencode-zen/kimi-k2.6": 2,
      "cloudflare/@cf/meta/llama-3.3-70b-instruct-fp8-fast": 5,
      "cloudflare/@cf/openai/gpt-oss-120b": 2,
      "cloudflare/@cf/qwen/qwen2.5-coder-32b-instruct": 3,
      "cloudflare/@cf/moonshotai/kimi-k2.7-code": 2,
      "cloudflare/@cf/nvidia/nemotron-3-120b-a12b": 2,
      "cloudflare/@cf/google/gemma-4-26b-a4b-it": 3,
      "cloudflare/@cf/zai-org/glm-4.7-flash": 5
    }
  },

  "agents": {
    // ── Lead Agent ───────────────────────────────────────────
    "sisyphus": {
      "model": "opencode-zen/big-pickle",
      "ultrawork": {
        "model": "opencode-zen/big-pickle",
        "variant": "xhigh"
      },
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "cloudflare/@cf/moonshotai/kimi-k2.7-code",
        "cerebras/gpt-oss-120b",
        "mistral/mistral-large-latest",
        "google/gemini-2.0-flash"
      ]
    },

    // ── Team Members ─────────────────────────────────────────
    "sisyphus-junior": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "openrouter/nvidia/nemotron-3-nano-30b-a3b:free",
        "opencode-zen/deepseek-v4-flash-free",
        "opencode-go/deepseek-v4-flash"
      ]
    },

    "hephaestus": {
      "model": "opencode-go/gpt-5.5",
      "permission": {
        "teammate": "allow"
      },
      "fallback_models": [
        "opencode-zen/gpt-5.5",
        "opencode-zen/gpt-5.4",
        "cloudflare/@cf/moonshotai/kimi-k2.7-code",
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    // ── Orchestration / Planning ─────────────────────────────
    "prometheus": {
      "model": "opencode-zen/big-pickle",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "cloudflare/@cf/moonshotai/kimi-k2.7-code",
        "opencode-go/deepseek-v4-pro",
        "cerebras/gpt-oss-120b"
      ]
    },

    "metis": {
      "model": "opencode-go/glm-5.1",
      "temperature": 0.3,
      "fallback_models": [
        "cloudflare/@cf/zai-org/glm-5.2",
        "opencode-zen/glm-5.1",
        "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "opencode-zen/deepseek-v4-flash-free",
        "opencode-go/deepseek-v4-flash"
      ]
    },

    "momus": {
      "model": "opencode/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        "opencode-zen/gpt-5.5-pro",
        "cloudflare/@cf/moonshotai/kimi-k2.7-code",
        "opencode-zen/big-pickle",
        "opencode/deepseek-v4-pro",
        "opencode-zen/kimi-k2.6"
      ]
    },

    // ── Execution ────────────────────────────────────────────
    "atlas": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "cloudflare/@cf/qwen/qwen2.5-coder-32b-instruct",
        "opencode-go/kimi-k2.6",
        "sambanova/Meta-Llama-3.3-70B-Instruct"
      ]
    },

    // ── Analysis / Research ──────────────────────────────────
    "oracle": {
      "model": "opencode/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        "opencode-zen/gpt-5.5-pro",
        "cloudflare/@cf/nvidia/nemotron-3-120b-a12b",
        "opencode-zen/big-pickle",
        "opencode/deepseek-v4-pro",
        "together/deepseek-ai/DeepSeek-R1"
      ]
    },

    "explore": {
      "model": "cloudflare/@cf/meta/llama-3.3-70b-instruct-fp8-fast",
      "temperature": 0.1,
      "fallback_models": [
        "cloudflare/@cf/google/gemma-4-26b-a4b-it",
        "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "opencode-zen/deepseek-v4-flash-free",
        "opencode-go/deepseek-v4-flash"
      ],
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },

    "librarian": {
      "model": "cloudflare/@cf/meta/llama-3.3-70b-instruct-fp8-fast",
      "temperature": 0.1,
      "fallback_models": [
        "cloudflare/@cf/nvidia/nemotron-3-120b-a12b",
        "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "opencode-zen/deepseek-v4-flash-free",
        "opencode-go/qwen3.5-plus",
        "opencode-go/deepseek-v4-flash"
      ]
    },

    "multimodal-looker": {
      "model": "huggingface/google/gemma-4-12b-it",
      "fallback_models": [
        "cloudflare/@cf/google/gemma-4-26b-a4b-it",
        "openrouter/nvidia/nemotron-nano-12b-v2-vl:free",
        "opencode-zen/mimo-v2.5-free",
        "opencode-zen/nemotron-3-ultra-free"
      ]
    },

    // ── Utility Agents (from Go merge) ────────────────────────────
    "quick": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "openrouter/nvidia/nemotron-3-nano-30b-a3b:free",
        "opencode-zen/deepseek-v4-flash-free",
        "opencode-go/deepseek-v4-flash"
      ]
    },

    "unspecified-low": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "openrouter/nvidia/nemotron-3-nano-30b-a3b:free",
        "opencode-zen/deepseek-v4-flash-free",
        "opencode-go/deepseek-v4-flash"
      ]
    }
  },

  "categories": {
    "visual-engineering": {
      "model": "opencode/gpt-5.3-codex",
      "fallback_models": [
        "opencode-zen/gpt-5.3-codex",
        "openrouter/nvidia/nemotron-nano-12b-v2-vl:free",
        "opencode-zen/deepseek-v4-flash-free",
        "opencode-go/deepseek-v4-flash"
      ]
    },

    "ultrabrain": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "xhigh",
      "fallback_models": [
        "cloudflare/@cf/deepseek-ai/deepseek-r1-distill-qwen-32b",
        "opencode-zen/big-pickle",
        "cerebras/gpt-oss-120b",
        "mistral/mistral-large-latest",
        "together/deepseek-ai/DeepSeek-R1"
      ]
    },

    "deep": {
      "model": "opencode-zen/big-pickle",
      "fallback_models": [
        "cloudflare/@cf/openai/gpt-oss-120b",
        "opencode-go/kimi-k2.6",
        "cerebras/llama3.3-70b",
        "together/deepseek-ai/DeepSeek-R1"
      ]
    },

    "artistry": {
      "model": "huggingface/google/gemma-4-12b-it",
      "fallback_models": [
        "cloudflare/@cf/google/gemma-4-26b-a4b-it",
        "opencode-zen/nemotron-3-super-free",
        "cerebras/llama3.3-70b",
        "openrouter/horizon-beta"
      ]
    },

    "quick": {
      "model": "cloudflare/@cf/openai/gpt-oss-20b",
      "fallback_models": [
        "cloudflare/@cf/zai-org/glm-4.7-flash",
        "opencode-zen/nemotron-3-super-free",
        "cerebras/llama3.3-70b",
        "huggingface/google/gemma-4-12b-it"
      ]
    },

    "unspecified-low": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "openrouter/nvidia/nemotron-3-nano-30b-a3b:free",
        "opencode-zen/deepseek-v4-flash-free",
        "opencode-go/deepseek-v4-flash"
      ]
    },

    "unspecified-high": {
      "model": "opencode-zen/big-pickle",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "cloudflare/@cf/nvidia/nemotron-3-120b-a12b",
        "cerebras/gpt-oss-120b",
        "mistral/mistral-large-latest",
        "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "together/deepseek-ai/DeepSeek-R1"
      ]
    },

    "writing": {
      "model": "cloudflare/@cf/meta/llama-3.3-70b-instruct-fp8-fast",
      "fallback_models": [
        "cloudflare/@cf/zai-org/glm-4.7-flash",
        "opencode-zen/nemotron-3-super-free",
        "cerebras/llama3.3-70b",
        "openrouter/meta-llama/llama-3.3-70b-instruct:free",
        "google/gemini-2.0-flash"
      ]
    }
  }
}
