      }
    },
    "mistral": {
      "npm": "@ai-sdk/mistral",
      "name": "Mistral",
      "options": {
        "apiKey": "{env:MISTRAL_API_KEY}"
      },
      "models": {
        "mistral-large-latest": { "name": "Mistral Large", "limit": { "context": 131072, "output": 8192 } }
      }
    },
    "sambanova": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "SambaNova",
      "options": {
        "baseURL": "https://api.sambanova.ai/v1",
        "apiKey": "{env:SAMBANOVA_API_KEY}"
      },
      "models": {
        "Meta-Llama-3.3-70B-Instruct": { "name": "Llama 3.3 70B", "limit": { "context": 131072, "output": 8192 } }
      }
    },
    "google": {
      "npm": "@ai-sdk/google",
      "name": "Google",
      "options": {
        "apiKey": "{env:GOOGLE_API_KEY}"
      },
      "models": {
        "gemini-2.0-flash": { "name": "Gemini 2.0 Flash", "limit": { "context": 1048576, "output": 8192 } }
      }
    },
    "together": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Together",
      "options": {
        "baseURL": "https://api.together.xyz/v1",
        "apiKey": "{env:TOGETHER_API_KEY}"
      },
      "models": {
        "deepseek-ai/DeepSeek-R1": { "name": "DeepSeek R1", "limit": { "context": 131072, "output": 8192 } }
      }
    },
    "kilocode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kilo Gateway",
      "options": {
        "baseURL": "https://api.kilo.ai/api/gateway"
      },
      "models": {
        "kilo-auto/free": { "name": "Kilo Auto Free", "limit": { "context": 131072, "output": 8192 } },
        "nvidia/nemotron-3-nano-30b-a3b:free": { "name": "Nemotron 3 Nano 30B", "limit": { "context": 131072, "output": 8192 } },
        "x-ai/grok-code-fast-1:optimized:free": { "name": "Grok Code Fast", "limit": { "context": 131072, "output": 8192 } },
        "arcee-ai/trinity-large-thinking:free": { "name": "Trinity Large Thinking", "limit": { "context": 131072, "output": 8192 } }
      }
    },
    "huggingface": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "HuggingFace",
      "options": {
        "baseURL": "https://router.huggingface.co/v1"
      },
      "models": {
        "deepseek-ai/DeepSeek-R1-0528": { "name": "DeepSeek R1 0528", "limit": { "context": 131072, "output": 8192 } },
        "Qwen/Qwen3-Coder-480B-A35B-Instruct": { "name": "Qwen3 Coder 480B", "limit": { "context": 131072, "output": 8192 } },
        "Qwen/Qwen3-235B-A22B-Instruct-2507": { "name": "Qwen3 235B", "limit": { "context": 131072, "output": 8192 } },
        "Qwen/QwQ-32B": { "name": "QwQ 32B", "limit": { "context": 131072, "output": 8192 } },
        "google/gemma-4-12b-it": { "name": "Gemma 4 12B", "limit": { "context": 262144, "output": 8192 } }
      }
    },
    "opencode-zen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Zen",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1",
        "apiKey": "{env:OPENCODE_ZEN_API_KEY}"
      },
      "models": {
        "big-pickle": { "name": "Big Pickle", "limit": { "context": 200000, "output": 32768 } },
        "mimo-v2.5-free": { "name": "MiMo V2.5 Free", "limit": { "context": 131072, "output": 8192 } },
        "nemotron-3-super-free": { "name": "Nemotron 3 Super Free", "limit": { "context": 262144, "output": 8192 } }
      }
    }
  },
  "compaction": {
    "auto": false,
    "prune": true,
    "reserved": 50000,
    "tail_turns": 40
  },
  "permission": "allow",
  "mcp": {
    "netdata-bylocalhost": {
      "type": "remote",
      "url": "http://localhost:19999/mcp",
      "enabled": true
    },
    "mcp_everything": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-everything"
      ]
    },
    "chrome-devtools": {
      "enabled": true,
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "google-workspace": {
      "enabled": true,
      "type": "local",
      "command": [
        "node",
        "/home/ubuntu/google-mcp-server/index.js"
      ],
      "env": {
        "GOOGLE_CLIENT_ID": "{env:GOOGLE_CLIENT_ID}",
        "GOOGLE_CLIENT_SECRET": "{env:GOOGLE_CLIENT_SECRET}",
        "GOOGLE_TOKEN_PATH": "/home/ubuntu/.google-mcp/credentials.json"
      }
    },
    "codemem": {
      "enabled": true,
      "type": "local",
      "command": [
        "codemem",
        "mcp"
      ]
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ]
}
