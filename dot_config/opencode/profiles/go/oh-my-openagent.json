{
  /*
   * ── CONSOLIDATED OmO AGENT CONFIG (Jun 2026) ──
   *
   * Philosophy: Go pool as primary for Tier 1 (quality agents), Zen free tier
   * as primary for Tier 2 (high-volume utility agents). Balance toggle handles
   * Go pool exhaustion seamlessly — same models via Zen balance billing.
   *
   * Fallback chains account for both failure modes:
   *   Mode A — Personal Go quota exhausted → balance toggle → seamless
   *   Mode B — Upstream provider depleted (402/429) → fallback chain activates
   *
   * 429/402 in retry_on_errors = cheap insurance against recurring upstream
   * provider depletion events (affects Kimi, DeepSeek, MiMo, GLM — 11/12 models
   * have experienced this).
   *
   * Gemini-2.0-flash set as small_model in global opencode.json (unchanged).
   */

  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-openagent.schema.json",

  "disabled_hooks": [
    "no-hephaestus-non-gpt"
  ],

  "model_fallback": true,

  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [401, 402, 429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 120,
    "timeout_seconds": 180,
    "notify_on_fallback": true
  },

  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "opencode-go":    5,
      "opencode-zen":   15,
      "opencode":       15,
      "groq":           8,
      "openrouter":     6
    },
    "modelConcurrency": {
      "opencode-go/big-pickle":          2,
      "opencode-go/deepseek-v4-pro":     2,
      "opencode-go/gpt-5.5":             2,
      "opencode-go/gpt-5.4":             2,
      "opencode-go/gpt-5.3-codex":       2,
      "opencode-go/glm-5.1":             2,
      "opencode-go/deepseek-v4-flash":   8,
      "opencode-go/kimi-k2.6":           2
    }
  },

  /*
   * ═══════════════════════════════════════════════════
   * TIER 1 — QUALITY AGENTS
   * ═══════════════════════════════════════════════════
   * Primary: Go pool models (quality, $12/5hr cap)
   * Fallback 1: Same model via Zen balance (seamless, covers Mode A)
   * Fallback 2: Zen free tier (covers Mode B when upstream provider fails)
   * Fallback 3: OpenRouter free (last resort)
   */

  "agents": {
    "sisyphus": {
      "model": "opencode-go/big-pickle",
      "ultrawork": {
        "model": "opencode-go/big-pickle",
        "variant": "xhigh"
      },
      "fallback_models": [
        "opencode-zen/big-pickle",
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "prometheus": {
      "model": "opencode-go/big-pickle",
      "fallback_models": [
        "opencode-zen/big-pickle",
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "metis": {
      "model": "opencode-go/glm-5.1",
      "fallback_models": [
        "opencode-zen/glm-5.1",
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "momus": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "xhigh",
      "fallback_models": [
        "opencode-zen/deepseek-v4-pro",
        "opencode-go/big-pickle",
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "oracle": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "xhigh",
      "fallback_models": [
        "opencode-zen/deepseek-v4-pro",
        "opencode-zen/big-pickle",
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "hephaestus": {
      "model": "opencode-go/gpt-5.5",
      "fallback_models": [
        "opencode-zen/gpt-5.5",
        "opencode-zen/gpt-5.4",
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    /*
     * ═══════════════════════════════════════════════════
     * TIER 2 — HIGH-VOLUME UTILITY AGENTS
     * ═══════════════════════════════════════════════════
     * Primary: Zen free tier (no cost, unlimited)
     * Fallback: Go pool (cheap models) when free tier fails
     * Last resort: OpenRouter free
     */

    "sisyphus-junior": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/deepseek-v4-flash-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "atlas": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/deepseek-v4-flash-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "explore": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/deepseek-v4-flash-free",
        "openrouter/qwen/qwen3-coder:free"
      ],
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },

    "librarian": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/deepseek-v4-flash-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "quick": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/deepseek-v4-flash-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "unspecified-low": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/deepseek-v4-flash-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    /*
     * ═══════════════════════════════════════════════════
     * TIER 3 — SPECIALIZED AGENTS
     * ═══════════════════════════════════════════════════
     */

    "multimodal-looker": {
      "model": "huggingface/google/gemma-4-12b-it",
      "fallback_models": [
        "openrouter/nvidia/nemotron-nano-12b-v2-vl:free",
        "opencode-zen/mimo-v2.5-free",
        "opencode-zen/nemotron-3-ultra-free"
      ]
    }
  },

  /*
   * ═══════════════════════════════════════════════════
   * CATEGORIES
   * ═══════════════════════════════════════════════════
   * Used by task() delegation. Same Tier 1/Tier 2 split.
   */

  "categories": {
    "visual-engineering": {
      "model": "opencode-go/gpt-5.3-codex",
      "fallback_models": [
        "opencode-zen/gpt-5.3-codex",
        "opencode-zen/claude-sonnet-4-6",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "ultrabrain": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "xhigh",
      "fallback_models": [
        "opencode-zen/deepseek-v4-pro",
        "opencode-zen/big-pickle",
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "deep": {
      "model": "opencode-go/big-pickle",
      "fallback_models": [
        "opencode-zen/big-pickle",
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "artistry": {
      "model": "huggingface/google/gemma-4-12b-it",
      "fallback_models": [
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "quick": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/deepseek-v4-flash-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "unspecified-low": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/deepseek-v4-flash-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "unspecified-high": {
      "model": "opencode-go/big-pickle",
      "fallback_models": [
        "opencode-zen/big-pickle",
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "writing": {
      "model": "groq/llama-3.3-70b-versatile",
      "fallback_models": [
        "opencode-zen/nemotron-3-ultra-free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    }
  }
}
