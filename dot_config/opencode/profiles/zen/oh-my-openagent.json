{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-openagent.schema.json",

  "disabled_hooks": [],

  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [401, 402, 429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 120,
    "timeout_seconds": 180,
    "notify_on_fallback": true
  },

  "background_task": {
    "defaultConcurrency": 8,
    "providerConcurrency": {
      "opencode": 15,
      "opencode-zen": 15,
      "opencode-go": 4,
      "groq": 8,
      "openrouter": 6
    },
    "modelConcurrency": {
      "opencode-zen/kimi-k2.6": 3,
      "opencode-zen/deepseek-v4-pro": 2,
      "opencode-zen/nemotron-3-ultra-free": 10,
      "opencode-go/kimi-k2.6": 2,
      "opencode-go/deepseek-v4-flash": 8
    }
  },

  "agents": {
    "sisyphus": {
      "model": "opencode-zen/big-pickle",
      "ultrawork": {
        "model": "opencode-zen/big-pickle",
        "variant": "xhigh"
      },
      "fallback_models": [
        "opencode-zen/kimi-k2.6",
        "opencode-go/kimi-k2.6",
        "cerebras/gpt-oss-120b",
        "mistral/mistral-large-latest",
        "google/gemini-2.0-flash"
      ]
    },

    "sisyphus-junior": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/big-pickle",
        "groq/openai/gpt-oss-20b",
        "cerebras/llama3.3-70b",
        "huggingface/google/gemma-4-12b-it"
      ]
    },

    "prometheus": {
      "model": "opencode-zen/big-pickle",
      "fallback_models": [
        "opencode-zen/kimi-k2.6",
        "opencode-go/kimi-k2.6",
        "opencode-go/deepseek-v4-pro",
        "cerebras/gpt-oss-120b"
      ]
    },

    "metis": {
      "model": "opencode-zen/glm-5.1",
      "fallback_models": [
        "opencode-zen/gpt-5.4",
        "opencode-go/glm-5.1",
        "groq/llama-3.3-70b-versatile",
        "cerebras/llama3.3-70b",
        "sambanova/Meta-Llama-3.3-70B-Instruct",
        "together/deepseek-ai/DeepSeek-R1"
      ]
    },

    "momus": {
      "model": "opencode-zen/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "opencode-zen/claude-sonnet-4-6",
        "opencode-go/kimi-k2.6",
        "cerebras/gpt-oss-120b",
        "together/deepseek-ai/DeepSeek-R1"
      ]
    },

    "atlas": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/big-pickle",
        "opencode-go/kimi-k2.6",
        "groq/meta-llama/llama-4-scout-17b-16e-instruct",
        "sambanova/Meta-Llama-3.3-70B-Instruct"
      ]
    },

    "hephaestus": {
      "model": "opencode-zen/gpt-5.5",
      "fallback_models": [
        "opencode-zen/gpt-5.4",
        "opencode-go/deepseek-v4-pro",
        "cerebras/gpt-oss-120b",
        "together/deepseek-ai/DeepSeek-R1"
      ]
    },

    "oracle": {
      "model": "opencode-zen/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "opencode-zen/claude-opus-4-5",
        "opencode-zen/big-pickle",
        "opencode-go/deepseek-v4-pro",
        "cerebras/gpt-oss-120b",
        "mistral/mistral-large-latest",
        "together/deepseek-ai/DeepSeek-R1"
      ]
    },

    "explore": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/big-pickle",
        "groq/openai/gpt-oss-20b",
        "cerebras/llama3.3-70b",
        "huggingface/google/gemma-4-12b-it"
      ],
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },

    "librarian": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/big-pickle",
        "groq/llama-3.3-70b-versatile",
        "cerebras/llama3.3-70b",
        "google/gemini-2.0-flash",
        "openrouter/horizon-beta"
      ]
    },

    "multimodal-looker": {
      "model": "huggingface/google/gemma-4-12b-it",
      "fallback_models": [
        "opencode-zen/mimo-v2.5-free",
        "openrouter/nvidia/nemotron-nano-12b-v2-vl:free",
        "cerebras/gpt-oss-120b"
      ]
    }
  },

  "categories": {
    "visual-engineering": {
      "model": "opencode-zen/gpt-5.3-codex",
      "fallback_models": [
        "opencode-zen/claude-sonnet-4-6",
        "opencode-zen/kimi-k2.6",
        "opencode-go/deepseek-v4-pro",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "ultrabrain": {
      "model": "opencode-zen/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "opencode-zen/claude-opus-4-5",
        "opencode-zen/big-pickle",
        "opencode-go/deepseek-v4-pro",
        "cerebras/gpt-oss-120b",
        "mistral/mistral-large-latest",
        "together/deepseek-ai/DeepSeek-R1"
      ]
    },

    "deep": {
      "model": "opencode-zen/big-pickle",
      "fallback_models": [
        "opencode-zen/kimi-k2.6",
        "opencode-go/kimi-k2.6",
        "groq/llama-3.3-70b-versatile",
        "cerebras/llama3.3-70b",
        "together/deepseek-ai/DeepSeek-R1"
      ]
    },

    "artistry": {
      "model": "huggingface/google/gemma-4-12b-it",
      "fallback_models": [
        "opencode-zen/nemotron-3-ultra-free",
        "groq/openai/gpt-oss-20b",
        "cerebras/llama3.3-70b",
        "openrouter/horizon-beta"
      ]
    },

    "quick": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/big-pickle",
        "groq/openai/gpt-oss-20b",
        "cerebras/llama3.3-70b",
        "huggingface/google/gemma-4-12b-it"
      ]
    },

    "unspecified-low": {
      "model": "opencode-zen/nemotron-3-ultra-free",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-zen/big-pickle",
        "groq/openai/gpt-oss-20b",
        "cerebras/llama3.3-70b",
        "huggingface/google/gemma-4-12b-it",
        "openrouter/horizon-beta"
      ]
    },

    "unspecified-high": {
      "model": "opencode-zen/big-pickle",
      "fallback_models": [
        "opencode-zen/kimi-k2.6",
        "opencode-go/kimi-k2.6",
        "cerebras/gpt-oss-120b",
        "mistral/mistral-large-latest",
        "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "together/deepseek-ai/DeepSeek-R1"
      ]
    },

    "writing": {
      "model": "groq/llama-3.3-70b-versatile",
      "fallback_models": [
        "opencode-zen/nemotron-3-ultra-free",
        "cerebras/llama3.3-70b",
        "openrouter/meta-llama/llama-3.3-70b-instruct:free",
        "google/gemini-2.0-flash"
      ]
    }
  }
}
