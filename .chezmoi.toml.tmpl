encryption = "age"
[age]
    identity = "~/.config/chezmoi/key.txt"
    recipient = "age1p5cu2lhvhjxq2rkzxlgk9ekknr3ang7n5nla5pst94ckm8jmmq9sp66mc5"

# ── Hermes+Honcho defaults ──────────────────────────────────────
# These are overridable via `chezmoi init --data` or per-machine
# data files at ~/.config/chezmoi/chezmoi.toml
[data]
    [data.mybrain]
        repoPath = "$HOME/mybrain"
        runnerImage = "python:3.11-slim"

    [data.hermes]
        sourceType = "github-release"
        githubOwner = "your-org"
        githubRepo = "hermes"
        version = "latest"
        listenAddr = "127.0.0.1:8443"
        logLevel = "info"

    [data.honcho]
        pipPackage = "honcho"
        version = "latest"
