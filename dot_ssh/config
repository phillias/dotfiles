Host primary55522
  IdentityFile ~/.ssh/id_ed25519_kali
  IdentityFile ~/.ssh/id_ed25519_inspironkali
  HostName primary55522.phillias.cc
  ProxyCommand /usr/bin/cloudflared access ssh --hostname %h
