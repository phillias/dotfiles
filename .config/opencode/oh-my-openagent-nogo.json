{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-openagent.schema.json",

  /*
   * ── DISABLED HOOKS ──
   */
  "disabled_hooks": [
    "no-hephaestus-non-gpt"
  ],

  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [401, 402, 429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 120,
    "timeout_seconds": 180,
    "notify_on_fallback": true
  },

  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "opencode": 10,
      "openrouter": 5
    },
    "modelConcurrency": {}
  },

  "agents": {
    "sisyphus": {
      "model": "openrouter/deepseek/deepseek-v4-flash:free",
      "ultrawork": {
        "model": "openrouter/deepseek/deepseek-v4-flash:free",
        "variant": "xhigh"
      },
      "fallback_models": [
        "openrouter/qwen/qwen3-coder:free",
        "openrouter/meta-llama/llama-3.3-70b-instruct:free",
        "openrouter/owl-alpha"
      ]
    },

    "sisyphus-junior": {
      "model": "openrouter/deepseek/deepseek-v4-flash:free",
      "fallback_models": [
        "openrouter/owl-alpha",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "prometheus": {
      "model": "openrouter/deepseek/deepseek-v4-flash:free",
      "fallback_models": [
        "openrouter/qwen/qwen3-coder:free",
        "openrouter/meta-llama/llama-3.3-70b-instruct:free",
        "opencode/big-pickle"
      ]
    },

    "metis": {
      "model": "openrouter/meta-llama/llama-3.3-70b-instruct:free",
      "fallback_models": [
        "openrouter/deepseek/deepseek-v4-flash:free",
        "openrouter/qwen/qwen3-coder:free",
        "openrouter/owl-alpha"
      ]
    },

    "momus": {
      "model": "openrouter/meta-llama/llama-3.3-70b-instruct:free",
      "fallback_models": [
        "openrouter/deepseek/deepseek-v4-flash:free",
        "openrouter/owl-alpha",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "atlas": {
      "model": "openrouter/deepseek/deepseek-v4-flash:free",
      "fallback_models": [
        "opencode/big-pickle",
        "openrouter/qwen/qwen3-coder:free",
        "openrouter/owl-alpha"
      ]
    },

    "hephaestus": {
      "model": "openrouter/qwen/qwen3-coder:free",
      "fallback_models": [
        "openrouter/deepseek/deepseek-v4-flash:free",
        "opencode/big-pickle",
        "openrouter/meta-llama/llama-3.3-70b-instruct:free"
      ]
    },

    "oracle": {
      "model": "openrouter/deepseek/deepseek-v4-flash:free",
      "variant": "xhigh",
      "fallback_models": [
        "openrouter/meta-llama/llama-3.3-70b-instruct:free",
        "openrouter/qwen/qwen3-coder:free",
        "opencode/big-pickle"
      ]
    },

    "explore": {
      "model": "openrouter/owl-alpha",
      "fallback_models": [
        "openrouter/deepseek/deepseek-v4-flash:free",
        "openrouter/qwen/qwen3-coder:free"
      ],
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },

    "librarian": {
      "model": "openrouter/deepseek/deepseek-v4-flash:free",
      "fallback_models": [
        "openrouter/owl-alpha",
        "openrouter/qwen/qwen3-coder:free",
        "openrouter/meta-llama/llama-3.3-70b-instruct:free"
      ]
    },

    "multimodal-looker": {
      "model": "openrouter/nvidia/nemotron-nano-12b-v2-vl:free",
      "fallback_models": [
        "openrouter/deepseek/deepseek-v4-flash:free",
        "openrouter/owl-alpha",
        "openrouter/qwen/qwen3-coder:free"
      ]
    }
  },

  "categories": {
    "visual-engineering": {
      "model": "openrouter/qwen/qwen3-coder:free",
      "fallback_models": [
        "openrouter/deepseek/deepseek-v4-flash:free",
        "opencode/big-pickle",
        "openrouter/owl-alpha"
      ]
    },

    "ultrabrain": {
      "model": "openrouter/deepseek/deepseek-v4-flash:free",
      "variant": "xhigh",
      "fallback_models": [
        "openrouter/meta-llama/llama-3.3-70b-instruct:free",
        "opencode/big-pickle",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "deep": {
      "model": "openrouter/meta-llama/llama-3.3-70b-instruct:free",
      "fallback_models": [
        "opencode/big-pickle",
        "openrouter/deepseek/deepseek-v4-flash:free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "artistry": {
      "model": "openrouter/deepseek/deepseek-v4-flash:free",
      "fallback_models": [
        "openrouter/owl-alpha",
        "openrouter/qwen/qwen3-coder:free",
        "opencode/big-pickle"
      ]
    },

    "quick": {
      "model": "openrouter/deepseek/deepseek-v4-flash:free",
      "fallback_models": [
        "openrouter/owl-alpha",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "unspecified-low": {
      "model": "openrouter/owl-alpha",
      "fallback_models": [
        "openrouter/deepseek/deepseek-v4-flash:free",
        "openrouter/qwen/qwen3-coder:free"
      ]
    },

    "unspecified-high": {
      "model": "opencode/big-pickle",
      "fallback_models": [
        "openrouter/deepseek/deepseek-v4-flash:free",
        "openrouter/qwen/qwen3-coder:free",
        "openrouter/meta-llama/llama-3.3-70b-instruct:free"
      ]
    },

    "writing": {
      "model": "opencode/big-pickle",
      "fallback_models": [
        "openrouter/meta-llama/llama-3.3-70b-instruct:free",
        "openrouter/deepseek/deepseek-v4-flash:free",
        "openrouter/owl-alpha"
      ]
    }
  }
}
