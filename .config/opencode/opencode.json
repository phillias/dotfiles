{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "groq/llama-3.3-70b-versatile",
  "provider": {
    "opencode-go": {
      "models": {
        "kimi-k2.6": { "name": "Kimi K2.6" },
        "kimi-k2.5": { "name": "Kimi K2.5" },
        "deepseek-v4-pro": { "name": "DeepSeek V4 Pro" },
        "deepseek-v4-flash": { "name": "DeepSeek V4 Flash" },
        "mimo-v2.5-pro": { "name": "MiMo V2.5 Pro" },
        "mimo-v2.5": { "name": "MiMo V2.5" },
        "minimax-m2.7": { "name": "MiniMax M2.7" },
        "minimax-m2.5": { "name": "MiniMax M2.5" },
        "glm-5": { "name": "GLM-5" },
        "glm-5.1": { "name": "GLM-5.1" },
        "qwen3.5-plus": { "name": "Qwen3.5 Plus" },
        "qwen3.6-plus": { "name": "Qwen3.6 Plus" }
      }
    },
    "groq": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Groq",
      "options": {
        "baseURL": "https://api.groq.com/openai/v1",
        "apiKey": "{env:GROQ_API_KEY}"
      },
      "models": {
        "llama-3.3-70b-versatile": { "name": "Llama 3.3 70B", "limit": { "context": 131072 } },
        "gpt-oss-120b": { "name": "GPT-OSS 120B", "limit": { "context": 131072 } },
        "gpt-oss-20b": { "name": "GPT-OSS 20B", "limit": { "context": 131072 } },
        "llama-4-scout-17b-16e-instruct": { "name": "Llama 4 Scout 17B", "limit": { "context": 131072 } },
        "qwen-3-32b": { "name": "Qwen3 32B", "limit": { "context": 131072 } }
      }
    },
    "openrouter": {
      "models": {
        "owl-alpha": {},
        "qwen/qwen3-coder:free": {},
        "deepseek/deepseek-v4-flash:free": {},
        "meta-llama/llama-3.3-70b-instruct:free": {},
        "nvidia/nemotron-3-super-120b-a12b:free": {},
        "openai/gpt-oss-20b:free": {},
        "anthropic/claude-sonnet-4": {},
        "anthropic/claude-3.5-haiku": {},
        "openai/gpt-4o": {},
        "openai/gpt-4o-mini": {},
        "google/gemini-2.5-flash": {},
        "google/gemini-2.5-pro": {},
        "deepseek/deepseek-chat": {},
        "meta-llama/llama-3.1-70b-instruct": {},
        "mistralai/mistral-large": {},
        "qwen/qwen-2.5-72b-instruct": {}
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 50000,
    "tail_turns": 40
  },
  "permission": "allow",
  "mcp": {
    "netdata-bylocalhost": {
      "type": "remote",
      "url": "http://localhost:19999/mcp",
      "enabled": true
    },
    "mcp_everything": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-everything"
      ]
    },
    "chrome-devtools": {
      "enabled": true,
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "codemem": {
      "enabled": true,
      "type": "local",
      "command": [
        "codemem",
        "mcp"
      ]
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ]
}
