{
  "$schema": "https://opencode.ai/config.json",

  /*
   * LOCAL-ONLY CONFIGURATION
   * This is the default opencode.json without codemem sync.
   * Use this on machines where you don't need cross-machine memory sharing.
   * For shared/codemem configuration, see opencode-codemem-shared.json
   */

  /*
   * Default fallback model — last resort in oh-my-openagent's model resolution chain.
   * Used when all agent/category model overrides and fallback_chains fail.
   */
  "model": "openrouter/meta-llama/llama-3.3-70b-instruct:free",

  /*
   * Small model used for compaction (session summarization) and title generation.
    * A cheap/free model is ideal since these are frequent, low-stakes tasks.
    */
  "small_model": "openrouter/meta-llama/llama-3.3-70b-instruct:free",

  "provider": {
    "opencode-go": {
      "models": {
        "kimi-k2.6": { "name": "Kimi K2.6" },
        "kimi-k2.5": { "name": "Kimi K2.5" },
        "deepseek-v4-pro": { "name": "DeepSeek V4 Pro" },
        "deepseek-v4-flash": { "name": "DeepSeek V4 Flash" },
        "mimo-v2.5-pro": { "name": "MiMo V2.5 Pro" },
        "mimo-v2.5": { "name": "MiMo V2.5" },
        "minimax-m2.7": { "name": "MiniMax M2.7" },
        "minimax-m2.5": { "name": "MiniMax M2.5" },
        "glm-5": { "name": "GLM-5" },
        "glm-5.1": { "name": "GLM-5.1" },
        "qwen3.5-plus": { "name": "Qwen3.5 Plus" },
        "qwen3.6-plus": { "name": "Qwen3.6 Plus" }
      }
    },
    "openrouter": {
      "models": {
        "anthropic/claude-sonnet-4": {},
        "anthropic/claude-3.5-haiku": {},
        "openai/gpt-4o": {},
        "openai/gpt-4o-mini": {},
        "google/gemini-2.5-flash": {},
        "google/gemini-2.5-pro": {},
        "deepseek/deepseek-chat": {},
        "meta-llama/llama-3.1-70b-instruct": {},
        "mistralai/mistral-large": {},
        "qwen/qwen-2.5-72b-instruct": {}
      }
    }
  },
  "mcp": {
    "netdata-bylocalhost": {
      "type": "remote",
      "url": "http://localhost:19999/mcp",
      "headers": {
        "Authorization": "Bearer 0102219a-cd82-4751-97c6-b95abf787e76"
      },
      "enabled": true
    },
    "mcp_everything": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-everything"
      ]
    },
    "chrome-devtools": {
      "enabled": true,
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 2,
    "preserve_recent_tokens": 8000,
    "reserved": 4000
  },

  "plugin": [
    "oh-my-openagent@latest"
  ]
}
