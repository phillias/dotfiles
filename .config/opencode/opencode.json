{
  "$schema": "https://opencode.ai/config.json",

  /*
   * Default fallback model — last resort in oh-my-openagent's model resolution chain.
   * Used when all agent/category model overrides and fallback_chains fail.
   */
  "model": "openrouter/meta-llama/llama-3.3-70b-instruct:free",

  /*
   * Small model used for compaction (session summarization) and title generation.
   * A cheap/free model is ideal since these are frequent, low-stakes tasks.
   */
  "small_model": "openrouter/meta-llama/llama-3.3-70b-instruct:free",

  "provider": {
    "openrouter": {
      "models": {
        "anthropic/claude-sonnet-4": {},
        "anthropic/claude-3.5-haiku": {},
        "openai/gpt-4o": {},
        "openai/gpt-4o-mini": {},
        "google/gemini-2.5-flash": {},
        "google/gemini-2.5-pro": {},
        "deepseek/deepseek-chat": {},
        "meta-llama/llama-3.1-70b-instruct": {},
        "mistralai/mistral-large": {},
        "qwen/qwen-2.5-72b-instruct": {}
      }
    }
  },
  "mcp": {
    "netdata-bylocalhost": {
      "type": "remote",
      "url": "http://localhost:19999/mcp",
      "headers": {
        "Authorization": "Bearer 0102219a-cd82-4751-97c6-b95abf787e76"
      },
      "enabled": true
    },
    "mcp_everything": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-everything"
      ]
    },
    "chrome-devtools": {
      "enabled": true,
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "codemem": {
      "enabled": true,
      "type": "local",
      "command": [
        "codemem",
        "mcp"
      ]
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ]
}
