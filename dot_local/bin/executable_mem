#!/usr/bin/env bash
# mem — filesystem + git agent memory CLI with TOON output
#
# Storage: markdown files with YAML frontmatter at $MEM_DIR/objects/<type>/<id>.md
# Sync: git pull/push to bare repo at $MEM_REMOTE (configurable, defaults to OCI bare)
# Search: ripgrep in v1 (literal + regex). v2 plan documented in §v2-strategy below.
#
# AXI compliance: TOON output, 3-4 default fields, truncation with --full, definitive empty
# states, structured errors on stdout, exit 0/1/2, no interactive prompts, --help on every
# subcommand.
#
# §v2-strategy (semantic search)
#   Why defer: at <5000 memories, `rg` returns <50 hits per query — agent can read all of
#   them, surfacing literal matches is cheaper than opaque cosine-sim. Vector search pays
#   off when you can't eyeball the top-50. Codemem's mistake was baking vectors in v1.
#   When to enable v2: search returns >50 hits where the right one isn't visible.
#   How (v2): sqlite-vec as a BUILD ARTIFACT in $MEM_DIR/.cache/index.sqlite, not source
#   of truth. ONNX runtime + Xenova/bge-small-en-v1.5 model (~80MB). Embed on write;
#   index rebuilds offline. NEVER use a hosted vector DB — adds external dep + latency.
#   Skip qmd: it runs a daemon. Vector tooling belongs in-process only.
#   v2 surface: `mem search <q> --features=vector` → DO NOT change default behavior.

set -uo pipefail

# --- Configuration -----------------------------------------------------------
MEM_DIR="${MEM_DIR:-$HOME/memories}"
MEM_REMOTE="${MEM_REMOTE:-origin}"
MEM_OBJECTS="$MEM_DIR/objects"
TRUNCATE_BYTES=500  # body preview limit; --full bypasses

# Memory types are first-class — driving the id namespace and the subfolder layout.
declare -A TYPE_PREFIX=(
  [constraint]=c  [decision]=d  [failure]=f  [howto]=h  [preference]=p
)
declare -A TYPE_DIR=(
  [constraint]=constraints  [decision]=decisions  [failure]=failures
  [howto]=howtos  [preference]=preferences
)
ORDERED_TYPES=(constraint decision failure howto preference)

# --- Helpers -----------------------------------------------------------------
die() {
  # Emit a structured TOON error and exit. $1=message, $2=exit_code, optional $3=help.
  local msg="$1" code="${2:-1}" help="${3:-}"
  printf 'error: %s\n' "$msg"
  [[ -n "$help" ]] && printf 'help: %s\n' "$help"
  exit "$code"
}

# Parse a single frontmatter field from a markdown memory file.
#   get_frontmatter <file> <field>  -> echoes value (empty if missing)
get_frontmatter() {
  local file="$1" field="$2"
  # frontmatter is between the first two lines that are exactly "---"
  awk -v field="$field" '
    /^---$/ { state++; next }
    state==1 && $0 ~ "^"field":" {
      sub("^"field":[[:space:]]*", "")
      gsub(/^["'"'"']|["'"'"']$/, "")
      print
      exit
    }
  ' "$file"
}

# Parse a list-style field (e.g., tags: [auth, jwt, bug] OR tags: ["auth", "jwt"]).
# Echoes comma-joined values, unquoted.
get_frontmatter_list() {
  local file="$1" field="$2"
  awk -v field="$field" '
    /^---$/ { state++; next }
    state==1 && $0 ~ "^"field":" {
      line=$0
      sub("^"field":[[:space:]]*", "", line)
      gsub(/^\[|\]$/, "", line)     # strip outer [ ]
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
      # strip quoting around each — handles both unquoted (a, b) and quoted ("a", "b")
      gsub(/"/, "", line)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
      # collapse ", , " → ","
      gsub(/[[:space:]]*,[[:space:]]*/, ",", line)
      gsub(/,+/i, ",", line)
      sub(/^,/, "", line)
      sub(/,$/, "", line)
      print line
      exit
    }
  ' "$file"
}

# Escape a string for TOON (commas are delimiters, so escape any embedded commas)
toon_escape() {
  local s="$1"
  # Replace literal commas with \, — TOON spec uses backslash escape
  s="${s//,/\\,}"
  # Replace newlines with spaces (TOON rows are single-line)
  s="${s//$'\n'/ }"
  # Trim trailing whitespace
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

# Build a memory file path from type + id.
path_for() {
  local type="$1" id="$2"
  local dir="${TYPE_DIR[$type]:-}"
  [[ -z "$dir" ]] && die "unknown type: $type" 2 "valid: ${ORDERED_TYPES[*]}"
  printf '%s/%s/%s.md' "$MEM_OBJECTS" "$dir" "$id"
}

# Resolve an id to a file path. Ids are unique across all types (per TYPE_PREFIX).
resolve_id() {
  local id="$1"
  # If user gave a prefix-less slug (e.g. "use-pnpm" without "c-"), try all type prefixes.
  if [[ -z "$id" ]] ; then return 1; fi
  for t in "${ORDERED_TYPES[@]}"; do
    local p="${TYPE_PREFIX[$t]}"
    # direct match (id starts with prefix-)
    if [[ "$id" == ${p}-* ]]; then
      local f="$(path_for "$t" "$id")"
      [[ -f "$f" ]] && { printf '%s' "$f"; return 0; }
    fi
    # suffix match (id is just the slug)
    local f="$(path_for "$t" "${p}-${id}")"
    [[ -f "$f" ]] && { printf '%s' "$f"; return 0; }
  done
  return 1
}

ensure_repo() {
  [[ -d "$MEM_DIR/.git" ]] || die "mem store not initialized at $MEM_DIR" 1 "run: mem init"
  [[ -d "$MEM_OBJECTS" ]] || die "objects/ missing at $MEM_OBJECTS" 1
}

# TOON list row printer. Reads stdin lines: id|type|title|confidence
print_toon_list() {
  local header="$1"  # e.g. results{rownyield}
  local -a rows=()
  while IFS='|' read -r id type title conf; do
    rows+=("$(printf '%s,%s,%s,%s' \
      "$(toon_escape "$id")" \
      "$(toon_escape "$type")" \
      "$(toon_escape "$title")" \
      "$(toon_escape "$conf")")")
  done
  local total=${#rows[@]}
  if (( total == 0 )); then
    printf 'mem[0]{id,type,title,confidence}:\n'
    return
  fi
  printf 'mem[%d]{id,type,title,confidence}:\n' "$total"
  for r in "${rows[@]}"; do printf '  %s\n' "$r"; done
}

# --- Commands ----------------------------------------------------------------

cmd_home() {
  ensure_repo
  # §8: content first — show last 5 memories + counts
  local total
  total=$(find "$MEM_OBJECTS" -name '*.md' -type f 2>/dev/null | wc -l | tr -d ' ')

  printf 'bin: %s\n' "$0"
  printf 'description: filesystem + git agent memory (TOON)\n'
  printf 'store: %s\n' "$MEM_DIR"
  printf 'remote: %s\n' "$MEM_REMOTE"
  printf 'counts[%d]{type,count}:\n' "${#ORDERED_TYPES[@]}"
  for t in "${ORDERED_TYPES[@]}"; do
    local dir="${TYPE_DIR[$t]}"
    local n
    n=$(find "$MEM_OBJECTS/$dir" -name '*.md' -type f 2>/dev/null | wc -l | tr -d ' ')
    printf '  %s,%d\n' "$t" "$n"
  done
  printf 'total: %d memories\n' "$total"

  # Recent up to 5 (by file mtime)
  if (( total > 0 )); then
    local render_n=$(( total < 5 ? total : 5 ))
    printf 'recent[%d]{id,type,title,confidence}:\n' "$render_n"
    find "$MEM_OBJECTS" -name '*.md' -type f -printf '%T@ %p\n' 2>/dev/null \
      | sort -rn | head -5 | while read -r _ f; do
        local id type title conf
        id=$(get_frontmatter "$f" id)
        type=$(get_frontmatter "$f" type)
        title=$(get_frontmatter "$f" title)
        conf=$(get_frontmatter "$f" confidence)
        printf '  %s,%s,%s,%s\n' \
          "$(toon_escape "$id")" \
          "$(toon_escape "$type")" \
          "$(toon_escape "$title")" \
          "$(toon_escape "$conf")"
      done
  fi

  printf 'help[3]:\n'
  printf '  Run `mem search "<query>"` to find by keyword\n'
  printf '  Run `mem add --type <type> --title "<title>"` to add a memory\n'
  printf '  Run `mem sync` to pull+push from the remote\n'
}

cmd_init() {
  # Always idempotent — §6
  mkdir -p "$MEM_OBJECTS"
  for t in "${ORDERED_TYPES[@]}"; do
    mkdir -p "$MEM_OBJECTS/${TYPE_DIR[$t]}"
  done
  if [[ ! -d "$MEM_DIR/.git" ]]; then
    git init -C "$MEM_DIR" >/dev/null 2>&1
    git -C "$MEM_DIR" config user.name "mem-anchor"
    git -C "$MEM_DIR" config user.email "mem@phillias.cc"
    printf 'mem: initialized at %s\n' "$MEM_DIR"
  else
    printf 'mem: already initialized at %s (no-op)\n' "$MEM_DIR"
  fi
  if [[ ! -f "$MEM_DIR/.gitignore" ]]; then
    printf '.cache/\n' > "$MEM_DIR/.gitignore"
  fi
  printf 'help[1]:\n  Run `mem add --type constraint --title "Use pnpm"` to add your first memory\n'
}

cmd_search() {
  ensure_repo
  [[ $# -eq 0 ]] && die "search requires a query" 2 "valid: \`mem search <query>\` [--type <t>] [--limit <n>]"
  local query="" type="" limit=50
  while (($#)); do
    case "$1" in
      --type)  type="$2"; shift 2 ;;
      --limit) limit="$2"; shift 2 ;;
      --help|-h) cmd_search_help; return 0 ;;
      --*) die "unknown flag $1 for search" 2 "valid: --type, --limit" ;;
      *) query="$query $1"; shift ;;
    esac
  done
  query="${query# }"
  [[ -z "$query" ]] && die "search requires a query" 2

  local search_root="$MEM_OBJECTS"
  [[ -n "$type" ]] && {
    local d="${TYPE_DIR[$type]:-}"
    [[ -z "$d" ]] && die "unknown type: $type" 2 "valid: ${ORDERED_TYPES[*]}"
    search_root="$MEM_OBJECTS/$d"
  }

  # §v2-strategy: see file header. v1 uses rg literally.
  local rg_out
  rg_out=$(rg -l --no-heading -i --max-count 1 \
    -g '*.md' \
    "$query" "$search_root" 2>/dev/null || true)
  local -a files=()
  if [[ -n "$rg_out" ]]; then
    while IFS= read -r f; do
      files+=("$f")
    done <<< "$rg_out"
  fi
  local total=${#files[@]}

  if (( total == 0 )); then
    # §5: definitive empty state — say zero with context
    printf 'mem[0]{id,type,title,confidence}:\n'
    printf 'count: 0 of 0 total\n'
    printf 'help[1]:\n  Run `mem add --type <type> --title "%s"` if this should be remembered\n' "$query"
    return 0
  fi

  # §4: include total count even when capped
  printf 'mem[%d]{id,type,title,confidence}:\n' "$(( total < limit ? total : limit ))"
  local i=0
  for f in "${files[@]}"; do
    (( i++ >= limit )) && break
    local id type_t title conf
    id=$(get_frontmatter "$f" id)
    type_t=$(get_frontmatter "$f" type)
    title=$(get_frontmatter "$f" title)
    conf=$(get_frontmatter "$f" confidence)
    printf '  %s,%s,%s,%s\n' \
      "$(toon_escape "$id")" \
      "$(toon_escape "$type_t")" \
      "$(toon_escape "$title")" \
      "$(toon_escape "$conf")"
  done
  printf 'count: %d of %d total\n' "$(( total < limit ? total : limit ))" "$total"
  (( total > limit )) && printf 'help[1]:\n  Run `mem search "%s" --limit %d` for more\n' "$query" "$total"
  printf 'help[1]:\n  Run `mem show <id>` for full body\n'
}

cmd_show() {
  ensure_repo
  [[ $# -lt 1 ]] && die "show requires an <id>" 2 "valid: \`mem show <id>\` [--full]"
  local id="" full=0
  while (($#)); do
    case "$1" in
      --full) full=1; shift ;;
      --help|-h) cmd_show_help; return 0 ;;
      --*) die "unknown flag $1 for show" 2 "valid: --full" ;;
      *) id="$1"; shift ;;
    esac
  done
  [[ -z "$id" ]] && die "show requires an <id>" 2

  local f
  f=$(resolve_id "$id") || die "no memory with id \`$id\`" 1

  local title type scope status conf created tags body
  title=$(get_frontmatter "$f" title)
  type=$(get_frontmatter "$f" type)
  scope=$(get_frontmatter "$f" scope)
  status=$(get_frontmatter "$f" status)
  conf=$(get_frontmatter "$f" confidence)
  created=$(get_frontmatter "$f" created)
  tags=$(get_frontmatter_list "$f" tags)

  # Body is everything after the closing --- line
  body=$(awk '
    BEGIN { state=0 }
    /^---$/ { state++; next }
    state >= 2 { print }
  ' "$f" | sed -e 's/^[[:space:]]*$//' )
  body="${body#"${body%%[![:space:]]*}"}"  # ltrim
  body="${body%"${body##*[![:space:]]}"}"  # rtrim

  local truncated=0
  local body_out="$body"
  if (( full == 0 )); then
    local body_len=${#body}
    if (( body_len > TRUNCATE_BYTES )); then
      body_out="${body:0:$TRUNCATE_BYTES}..."
      truncated=1
      total_chars_meta=" ($body_len bytes total)"
    fi
  fi

  printf 'memory:\n'
  printf '  id: %s\n' "$id"
  printf '  type: %s\n' "$type"
  printf '  title: %s\n' "$title"
  printf '  status: %s\n' "$status"
  printf '  scope: %s\n' "$scope"
  printf '  confidence: %s\n' "$conf"
  printf '  created: %s\n' "$created"
  [[ -n "$tags" ]] && printf '  tags: %s\n' "$tags"
  printf '  body: %s\n' "${body_out//$'\n'/\\n}"
  if (( truncated == 1 )); then
    printf '  truncated: %d bytes shown of %d total\n' "$TRUNCATE_BYTES" "${#body}"
    printf 'help[1]:\n  Run `mem show %s --full` for complete body\n' "$id"
  fi
}

cmd_add() {
  ensure_repo
  local type="" title="" body="" scope="" tags="" confidence="0.5"
  while (($#)); do
    case "$1" in
      --type)        type="$2"; shift 2 ;;
      --title)       title="$2"; shift 2 ;;
      --body)        body="$2"; shift 2 ;;
      --scope)       scope="$2"; shift 2 ;;
      --tags)        tags="$2"; shift 2 ;;
      --confidence)  confidence="$2"; shift 2 ;;
      --help|-h)     cmd_add_help; return 0 ;;
      --*)           die "unknown flag $1 for add" 2 "valid: --type, --title, --body, --scope, --tags, --confidence" ;;
      *)             die "add takes only flags, got positional: $1" 2 "valid: --type, --title, --body, --scope, --tags, --confidence" ;;
    esac
  done

  [[ -z "$type" ]]  && die "--type is required" 2 "valid: ${ORDERED_TYPES[*]}"
  [[ -z "$title" ]] && die "--title is required" 2
  local t="${TYPE_PREFIX[$type]:-}"
  [[ -z "$t" ]] && die "unknown type: $type" 2 "valid: ${ORDERED_TYPES[*]}"

  # Generate id: <type-prefix>-<datestamp>-<slug-from-title>
  local datestamp=$(date -u +"%Y-%m-%d")
  local slug
  slug=$(printf '%s' "$title" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-//; s/-$//; s/--+/-/g' \
    | cut -c1-40)
  local id="${t}-${datestamp}-${slug}"

  # Idempotency — §6. If file with same id exists (same title same day), no-op.
  local fpath
  fpath=$(path_for "$type" "$id")
  if [[ -f "$fpath" ]]; then
    printf 'memory:\n  id: %s\n  status: already-exists (no-op)\n' "$id"
    return 0
  fi

  mkdir -p "$(dirname "$fpath")"

  # Build tags YAML inline. Accept either "tag1,tag2" or "tag1 tag2".
  # Strip a leading dot (user typo from ".tag") and quote each tag for YAML safety.
  local tags_clean="${tags// /,}"
  tags_clean="${tags_clean//,,/,}"
  tags_clean="${tags_clean#,}"
  tags_clean="${tags_clean%,}"
  local tags_yaml="[]"
  if [[ -n "$tags_clean" ]]; then
    IFS=',' read -ra _tags_arr <<< "$tags_clean"
    local _quoted=()
    for _t in "${_tags_arr[@]}"; do
      _t="${_t//./}"           # strip errant leading dots
      _t="${_t## }"; _t="${_t% }"
      [[ -n "$_t" ]] && _quoted+=("$(printf '"%s"' "${_t//\"/\\\"}")")
    done
    [[ ${#_quoted[@]} -gt 0 ]] && tags_yaml="[$(IFS=, ; printf '%s' "${_quoted[*]}")]"
  fi

  # Write the markdown file
  {
    printf -- '---\n'
    printf 'id: %s\n' "$id"
    printf 'type: %s\n' "$type"
    printf 'title: %s\n' "$title"
    [[ -n "$scope" ]]   && printf 'scope: %s\n' "$scope"
    printf 'status: active\n'
    printf 'confidence: %s\n' "$confidence"
    printf 'created: %s\n' "$datestamp"
    printf 'tags: %s\n' "$tags_yaml"
    printf -- '---\n\n'
    printf '%s\n' "$body"
  } > "$fpath"

  # Track + commit (single commit per add)
  git -C "$MEM_DIR" add "$fpath" 2>/dev/null
  git -C "$MEM_DIR" commit -m "mem($type): $title" >/dev/null 2>&1 || true

  printf 'memory:\n'
  printf '  id: %s\n' "$id"
  printf '  type: %s\n' "$type"
  printf '  title: %s\n' "$title"
  printf '  saved: %s\n' "$fpath"
  printf 'help[1]:\n  Run `mem sync` to push to the remote\n'
}

cmd_list() {
  ensure_repo
  local type="" tag="" limit=100
  while (($#)); do
    case "$1" in
      --type)  type="$2"; shift 2 ;;
      --tag)   tag="$2"; shift 2 ;;
      --limit) limit="$2"; shift 2 ;;
      --help|-h) cmd_list_help; return 0 ;;
      --*) die "unknown flag $1 for list" 2 "valid: --type, --tag, --limit" ;;
      *) die "list takes only flags, got positional: $1" 2 ;;
    esac
  done

  local search_root="$MEM_OBJECTS"
  [[ -n "$type" ]] && {
    local d="${TYPE_DIR[$type]:-}"
    [[ -z "$d" ]] && die "unknown type: $type" 2 "valid: ${ORDERED_TYPES[*]}"
    search_root="$MEM_OBJECTS/$d"
  }

  local -a files=()
  while IFS= read -r f; do
    files+=("$f")
  done < <(find "$search_root" -name '*.md' -type f 2>/dev/null | sort)

  local -a matching=()
  for f in "${files[@]}"; do
    if [[ -n "$tag" ]]; then
      local tags
      tags=$(get_frontmatter_list "$f" tags)
      [[ ",$tags," != *",$tag,"* ]] && continue
    fi
    matching+=("$f")
  done

  local total=${#matching[@]}
  printf 'mem[%d]{id,type,title,confidence}:\n' "$(( total < limit ? total : limit ))"
  local i=0
  for f in "${matching[@]}"; do
    (( i++ >= limit )) && break
    local id type_t title conf
    id=$(get_frontmatter "$f" id)
    type_t=$(get_frontmatter "$f" type)
    title=$(get_frontmatter "$f" title)
    conf=$(get_frontmatter "$f" confidence)
    printf '  %s,%s,%s,%s\n' \
      "$(toon_escape "$id")" \
      "$(toon_escape "$type_t")" \
      "$(toon_escape "$title")" \
      "$(toon_escape "$conf")"
  done
  printf 'count: %d of %d total\n' "$(( total < limit ? total : limit ))" "$total"
  (( total > 0 )) && printf 'help[1]:\n  Run `mem show <id>` for full body\n'
  (( total == 0 )) && printf 'help[1]:\n  Run `mem add --type <type> --title "<title>"` to add a memory\n'
}

cmd_sync() {
  ensure_repo
  local status=0 output
  printf 'sync:\n'
  printf '  remote: %s\n' "$MEM_REMOTE"
  # Pull first to grab latest from the anchor
  if output=$(git -C "$MEM_DIR" pull --rebase "$MEM_REMOTE" "$(git -C "$MEM_DIR" config init.defaultBranch || echo master)" 2>&1); then
    printf '  pull: ok\n'
  else
    printf '  pull: %s\n' "$(printf '%s' "$output" | tail -3 | tr '\n' ' ')"
    status=1
  fi
  # Push our changes
  if output=$(git -C "$MEM_DIR" push "$MEM_REMOTE" HEAD 2>&1); then
    printf '  push: ok\n'
  else
    printf '  push: %s\n' "$(printf '%s' "$output" | tail -3 | tr '\n' ' ')"
    status=1
  fi
  # Brief status summary - §4 pre-computed
  local ahead behind
  ahead=$(git -C "$MEM_DIR" rev-list --count @{u}..HEAD 2>/dev/null || echo "?")
  behind=$(git -C "$MEM_DIR" rev-list --count HEAD..@{u} 2>/dev/null || echo "?")
  printf '  unpushed: %s commits ahead\n' "$ahead"
  printf '  unpulled: %s commits behind\n' "$behind"
  return $status
}

# --- Per-subcommand --help blocks (§10) --------------------------------------

cmd_help_top() {
  cat <<'EOF'
mem — filesystem + git agent memory with TOON output

Usage: mem [<command>] [<args>]

Commands:
  (no args)        show recent + status (content-first home view)
  init             initialize mem store at $MEM_DIR (idempotent)
  search <query>   ripgrep search across all memories
  show <id>        full detail (body truncated by default; use --full)
  add              create a new memory
  list             list memories (filter by --type / --tag)
  sync             git pull --rebase && git push
  --help           this message

Configuration (env):
  MEM_DIR          path to memory store (default: $HOME/memories)
  MEM_REMOTE       git remote name (default: origin)

Storage shape:
  $MEM_DIR/objects/<type>/<id>.md  (markdown + YAML frontmatter)
  $MEM_DIR/.git/                   (git repo)
  $MEM_DIR/.cache/                 (transient, gitignored)

Help per command:
  mem <command> --help
EOF
}

cmd_search_help() {
  cat <<'EOF'
mem search — keyword search across memories (v1: ripgrep literal + regex)

Usage: mem search <query> [--type <type>] [--limit <n>]

Flags:
  --type <type>     constrain to one type (constraint|decision|failure|howto|preference)
  --limit <n>       max rows in output (default: 50). Total count is always shown.
  --help            this message

Output: TOON list with id, type, title, confidence fields, plus total count.

Notes:
  - v1 uses ripgrep literal/regex matching against the entire markdown file
    (frontmatter + body). Semantic/vector search is deferred to v2 — see
    file-header §v2-strategy.
EOF
}

cmd_show_help() {
  cat <<'EOF'
mem show — full detail for one memory by id

Usage: mem show <id> [--full]

Flags:
  --full   bypass 500-byte body truncation, show complete body
  --help   this message

Id resolution:
  Ids may be passed full ("d-2026-07-19-auth-401") or as suffix ("2026-07-19-auth-401").
  The CLI tries all 5 type prefixes (constraint, decision, failure, howto, preference)
  and resolves the first match found on disk.
EOF
}

cmd_add_help() {
  cat <<'EOF'
mem add — create a new memory

Usage: mem add --type <type> --title "<title>" [--body "..."] [--scope "..."] [--tags "..."] [--confidence 0.5]

Required:
  --type <type>        constraint|decision|failure|howto|preference
  --title "<title>"    short title (used to generate the slug)

Optional:
  --body "<text>""     long-form markdown body
  --scope "<scope>"    free-text scope tag (project name, etc.)
  --tags "<csv>"       comma or space separated: "auth, jwt, bug"
  --confidence <f>     0.0-1.0 (default: 0.5)

Behavior:
  - Id is auto-generated: <type-prefix>-<date>-<slug>
  - File is written to $MEM_DIR/objects/<type>/<id>.md
  - Committed immediately (one commit per add)
  - Idempotent: re-adding the same title on the same day is a no-op (exit 0)

Examples:
  mem add --type constraint --title "Use pnpm" --body "Never run npm install in this repo." --tags "tooling"
  mem add --type failure --title "JWT decode panic" --body "prod crash at 04:32 UTC..." --scope phillias-api
EOF
}

cmd_list_help() {
  cat <<'EOF'
mem list — list memories

Usage: mem list [--type <type>] [--tag <tag>] [--limit <n>]

Flags:
  --type <type>   constrain to one type
  --tag <tag>     filter by tag (substring match)
  --limit <n>     max rows (default: 100)
  --help          this message

Output: TOON list with id, type, title, confidence, plus total count.

Examples:
  mem list --type failure
  mem list --tag auth --limit 20
EOF
}

# --- Top-level dispatcher -----------------------------------------------------

main() {
  # §8 content-first: `mem` with no args shows the home view (live state, not help).
  # `mem --help` / `mem help` / `mem -h` shows the top-level help block.
  if [[ $# -eq 0 ]]; then
    cmd_home
    return $?
  fi
  local cmd="$1"
  if [[ "$cmd" == "--help" || "$cmd" == "-h" || "$cmd" == "help" ]]; then
    cmd_help_top
    return 0
  fi
  shift
  case "$cmd" in
    init)   cmd_init   "$@" ;;
    search) cmd_search "$@" ;;
    show)   cmd_show   "$@" ;;
    add)    cmd_add    "$@" ;;
    list)   cmd_list   "$@" ;;
    sync)   cmd_sync   "$@" ;;
    *)
      die "unknown command: $cmd" 2 "run \`mem --help\` for the command list"
      ;;
  esac
}

main "$@"