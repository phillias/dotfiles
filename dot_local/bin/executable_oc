#!/bin/bash
set -euo pipefail

PROFILES_DIR="${HOME}/.config/opencode/profiles"
MODE="${1:-}"

usage() {
  cat <<EOF
Usage: oc <mode> [opencode-args...]

Modes:
  free     OpenCode + Free agents (default OmO)
  go       OpenCode + Go agents (OpenCode Go subscription)
  nogo     Alias for free
  zen      OpenCode Zen + Zen agents (Zen subscription)
  team     OpenCode Zen + Team agents + tmux OmO layout
  web      OpenCode Google + Free agents (Google-provider focus)
  desk     Alias for free
  pure     OpenCode with no oh-my-openagent plugin (vanilla)
EOF
  exit 1
}

[ -z "${MODE}" ] && usage

case "${MODE}" in
  free|go|nogo|zen|team|web|desk|pure) ;;
  *) usage ;;
esac

# Resolve aliases, set env, then launch
case "${MODE}" in
  nogo|desk)
    PROFILE="free" ;;
  go)
    PROFILE="go" ;;
  zen)
    PROFILE="zen" ;;
  team)
    PROFILE="team"
    export TMUX_CONF="${HOME}/.config/opencode/.tmux-OmOTeam.conf" ;;
  web)
    PROFILE="web" ;;
  *)
    PROFILE="${MODE}" ;;
esac

PROFILE_DIR="${PROFILES_DIR}/${PROFILE}"

if [ ! -d "${PROFILE_DIR}" ]; then
  echo "error: profile directory not found: ${PROFILE_DIR}" >&2
  exit 1
fi

export OPENCODE_CONFIG_DIR="${PROFILE_DIR}"

# Load API keys from key files (only when running opencode, not in shell env)
KEYS_DIR="${HOME}/.config/opencode"
_load_key() { [ -f "${KEYS_DIR}/$1" ] && export "$2"="$(cat "${KEYS_DIR}/$1")"; }
_load_key .groq-key              GROQ_API_KEY
_load_key .cerebras-key          CEREBRAS_API_KEY
_load_key .mistral-key           MISTRAL_API_KEY
_load_key .sambanova-key         SAMBANOVA_API_KEY
_load_key .google-key            GOOGLE_API_KEY
_load_key .together-key          TOGETHER_API_KEY
_load_key .zen-key               OPENCODE_ZEN_API_KEY
_load_key .google-client-id      GOOGLE_CLIENT_ID
_load_key .google-client-secret  GOOGLE_CLIENT_SECRET
unset -v KEYS_DIR

shift 1
exec opencode "$@"
