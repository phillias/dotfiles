#!/bin/bash
set -euo pipefail

PROFILES_DIR="${HOME}/.config/opencode/profiles"
MODE="${1:-}"

usage() {
  cat <<EOF
Usage: oc <mode> [opencode-args...]

Modes:
  free     OpenCode + Free agents (default OmO)
  go       OpenCode + Go agents (OpenCode Go subscription)
  nogo     Alias for free
  pure     No OmO
  zen      OpenCode Zen + Zen agents (Zen subscription)
  team     OpenCode Zen + Team agents + tmux OmO layout
  web      OpenCode Google + Free agents (Google-provider focus)
  desk     Alias for free
EOF
  exit 1
}

[ -z "${MODE}" ] && usage

case "${MODE}" in
  pure|free|go|nogo|zen|team|web|desk) ;;
  *) usage ;;
esac

# Resolve aliases, set env, then launch
case "${MODE}" in
  nogo|desk)
    PROFILE="free" ;;
  go)
    PROFILE="go" ;;
  zen)
    PROFILE="zen" ;;
  team)
    PROFILE="team"
    export TMUX_CONF="${HOME}/.config/opencode/.tmux-OmOTeam.conf" ;;
  web)
    PROFILE="web" ;;
  pure)
    PROFILE="pure" ;;
  *)
    PROFILE="${MODE}" ;;
esac

# Load keys from ~/.config/opencode/
for key_file in "${HOME}/.config/opencode/".*-key; do
  [ -f "$key_file" ] || continue
  filename=$(basename "$key_file")
  provider=${filename#.}
  provider=${provider%-key}

  case "$provider" in
    zen) var="OPENCODE_ZEN_API_KEY" ;;
    *) var="$(echo "$provider" | tr '[:lower:]' '[:upper:]')_API_KEY" ;;
  esac

  export "$var"=$(cat "$key_file")
done

PROFILE_DIR="${PROFILES_DIR}/${PROFILE}"

if [ ! -d "${PROFILE_DIR}" ]; then
  echo "error: profile directory not found: ${PROFILE_DIR}" >&2
  exit 1
fi

export OPENCODE_CONFIG_DIR="${PROFILE_DIR}"

shift 1
exec opencode "$@"
